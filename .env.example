# Fichier .env - Configuration d'environnement
# Copier ce fichier en .env.local et remplir les valeurs

# Flask Configuration
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=your-secret-key-change-this

# Base de données (optionnel)
# DATABASE_URL=postgresql://user:password@localhost/bamtaare_db

# Email Configuration (pour les notifications)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password

# API Configuration
API_HOST=localhost
API_PORT=5000
DEBUG=True

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# Production (à décommenter pour production)
# FLASK_ENV=production
# DEBUG=False
